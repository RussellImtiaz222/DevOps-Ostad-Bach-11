{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowTerraformDeployment",
            "Effect": "Allow",
            "Action": [
                "iam:*",
                "ec2:*",
                "rds:*",
                "elasticloadbalancing:*",
                "autoscaling:*"
            ],
            "Resource": "*"
        }
    ]
}
