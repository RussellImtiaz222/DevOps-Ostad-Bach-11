# Environment Configuration for Monitoring Stack
# Copy this file to .env and update with your actual values

# =======================
# Grafana Configuration
# =======================
GRAFANA_PASSWORD=admin123
GRAFANA_USER=admin

# =======================
# SMTP Configuration
# Email alerts configuration for AlertManager
# =======================
# Example: For Gmail - use your Gmail address and generate an App Password
# https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# =======================
# Alert Email Configuration
# =======================
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_EMAIL_TO=ops@yourdomain.com
ALERT_CRITICAL_EMAIL_TO=oncall@yourdomain.com

# =======================
# AWS Configuration
# For CloudWatch Exporter
# =======================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# =======================
# Application Configuration
# =======================
APP_ENV=dev
DB_HOST=postgres.internal
DB_NAME=appdb
DB_USER=appuser

# =======================
# Data Retention Configuration
# =======================
# Prometheus retention time (30d = 30 days)
PROMETHEUS_RETENTION=30d
