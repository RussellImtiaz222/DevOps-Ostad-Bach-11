# BMI Health Tracker Backend Environment Variables
# Copy this file to .env and fill in with your actual values

# Database Configuration
DATABASE_URL=postgresql://bmi_user:your_password@localhost:5432/bmidb
DB_HOST=localhost
DB_PORT=5432
DB_USER=bmi_user
DB_PASSWORD=your_password
DB_NAME=bmidb

# Application Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
